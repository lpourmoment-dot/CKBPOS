{
  "name": "ckbpos",
  "version": "5.0.9",
  "description": "CKBPOS - Application Point de Vente Professionnelle",
  "main": "main.js",
  "author": "CKB",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "dist": "electron-builder --win",
    "publish-update": "electron-builder --win --publish always",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "verify": "node scripts/verify-build.js",
    "verify:post-build": "node scripts/verify-build.js --post-build",
    "predist": "npm run verify && npm run react-build && npm run rebuild"
  },
  "build": {
    "appId": "com.ckb.pos",
    "productName": "CKBPOS",
    "extends": null,
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources/platform-tools",
        "to": "platform-tools",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CKBPOS",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "include": "installer.nsh"
    },
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "license-ipc.js",
      "licensing.js",
      "license-keys.json",
      "integrity-manifest.json",
      "package.json",
      "scripts/**/*",
      "src/main/**/*",
      "src/utils/adaptive-print.js",
      "src/utils/printer-detect.js",
      "src/utils/escpos.js",
      "database/**/*",
      "assets/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/ws/**/*",
      "node_modules/@supabase/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "lpourmoment-dot",
      "repo": "ckbpos",
      "channel": "latest",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "date-fns": "^3.3.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.4",
    "framer-motion": "^11.18.2",
    "googleapis": "^140.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.344.0",
    "nodemailer": "^8.0.10",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.12.0",
    "uuid": "^9.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "concurrently": "^8.2.2",
    "electron": "^41.7.1",
    "electron-builder": "^24.13.3",
    "node-abi": "^4.32.0",
    "wait-on": "^7.2.0"
  },
  "homepage": "./",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}
